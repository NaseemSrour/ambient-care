# Copy this file to `.env` and change the values before deploying.

# The single shared passcode the whole family uses to log in.
AC_FAMILY_PASSCODE=1234

# Secret used to sign login tokens (JWT). MUST be a long random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AC_JWT_SECRET=change-me-please-use-a-long-random-string

# How long a family member stays logged in (days).
AC_JWT_EXPIRE_DAYS=90

# All dates/times are computed in this timezone.
AC_TIMEZONE=Asia/Jerusalem

# Arabic display font on the elder's screen. One of:
#   Cairo | Tajawal | Almarai | Noto Kufi Arabic | Noto Naskh Arabic
#   | IBM Plex Sans Arabic | Amiri
AC_DISPLAY_FONT=Cairo

# Day-mode background color. Keep it VERY light — the TRMNL panel is 1-bit
# black/white, so anything but a near-white reads as grainy on the device.
# Soft warm ivory by default; use #FFFFFF for pure white.
AC_DAY_BG=#F4F1EA

# Family messages older than this many hours are automatically hidden.
AC_MESSAGE_TTL_HOURS=24

# Optional secret the TRMNL device must send as ?key=... when polling /api/trmnl-payload.
# Leave blank to allow open polling (fine for early testing).
AC_TRMNL_POLL_KEY=

# SQLite database file location (relative to backend/).
AC_DATABASE_PATH=data/ambient_care.db

# Reassuring fallback shown when there is no fresh family message.
AC_DEFAULT_MESSAGE=نحن نحبّك ونفكّر بك دائماً. نتمنّى لك يوماً هادئاً وجميلاً
